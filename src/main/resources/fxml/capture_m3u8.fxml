<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.HBox?>
<?import java.lang.String?>
<?import javafx.scene.layout.VBox?>
<VBox fx:controller="com.github.cloudgyb.m3u8downloader.viewcontroller.CaptureM3u8ViewController"
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
    <HBox style="-fx-spacing: 20.0">
        <Button mnemonicParsing="false" onAction="#proxySwitch" prefHeight="38.0" text="启动代理服务器">
            <styleClass>
                <String fx:value="btn"/>
                <String fx:value="btn-primary"/>
            </styleClass>
            <HBox.margin>
                <Insets left="10.0"/>
                <Insets top="10.0"/>
                <Insets bottom="10.0"/>
            </HBox.margin>
        </Button>

    </HBox>
    <TableView fx:id="downloadHistoryTable">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" style="-fx-alignment: center"/>
            <TableColumn fx:id="urlColumn" text="URL" style="-fx-alignment: center"/>
            <TableColumn fx:id="createTimeColumn" text="创建时间" style="-fx-alignment: center"/>
            <TableColumn fx:id="finishTimeColumn" text="完成时间" sortType="DESCENDING" style="-fx-alignment: center"/>
            <TableColumn fx:id="durationColumn" text="耗时" style="-fx-alignment: center"/>
            <TableColumn fx:id="operaColumn" maxWidth="-1.0" minWidth="190.0" prefWidth="190.0" sortable="false"
                         text="操作" style="-fx-alignment: center"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <StackPane.margin>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
        </StackPane.margin>
    </TableView>
</VBox>
