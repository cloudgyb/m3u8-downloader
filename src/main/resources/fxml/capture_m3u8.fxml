<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.HBox?>
<?import java.lang.String?>
<?import javafx.scene.layout.VBox?>
<VBox fx:controller="com.github.cloudgyb.m3u8downloader.viewcontroller.CaptureM3u8ViewController"
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
    <HBox alignment="CENTER_RIGHT" prefHeight="32.0" style="-fx-padding: 10;">
        <Button fx:id="proxyServerSwitch" mnemonicParsing="false" onAction="#proxySwitch"
                prefHeight="38.0" text="启动代理服务器">
            <styleClass>
                <String fx:value="btn"/>
                <String fx:value="btn-primary"/>
            </styleClass>
        </Button>
    </HBox>
    <TableView fx:id="urlTable">
        <columns>
            <TableColumn fx:id="urlColumn" text="URL" style="-fx-alignment: center"/>
            <TableColumn fx:id="operaColumn" maxWidth="-1.0" minWidth="190.0" prefWidth="190.0" sortable="false"
                         text="操作" style="-fx-alignment: center"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <StackPane.margin>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
        </StackPane.margin>
    </TableView>
</VBox>
